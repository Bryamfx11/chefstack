# Variables del frontend (Vite). Copia este archivo a .env y completa los valores.
# Los valores de Firebase son publicos (viajan al navegador); ya vienen por defecto en el codigo.

# URL del backend. En local: http://localhost:8080 ; en produccion: la URL de Railway.
VITE_API_URL=http://localhost:8080

# Opcionales: solo si quieres sobreescribir la configuracion de Firebase por defecto
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_SENDER_ID=
# VITE_FIREBASE_APP_ID=
